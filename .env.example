# SonarQube / SonarCloud
# Create a read-only user token at: https://sonarcloud.io/account/security
SONARQUBE_TOKEN=your-sonarqube-token-here

# SonarCloud organisation key (required for SonarCloud, omit for self-hosted SonarQube)
SONARQUBE_ORG=your-org-key-here

# Jira / Atlassian (optional — only needed if jira is configured in config.json)
# Generate an OAuth token at: https://id.atlassian.com/manage-profile/security
JIRA_TOKEN=your-jira-token-here
