{
  "name": "dev-metrics-agent",
  "version": "0.1.0",
  "description": "AI-connected agent that retrieves, normalises, and reports on development team metrics via SonarQube and Jira MCP servers.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "validate-config": "node scripts/validate-config.mjs",
    "scan": "node -r dotenv/config dist/index.js --config config.json",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "validate": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "fast-check": "^3.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
